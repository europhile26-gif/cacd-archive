# Test Environment Configuration
# Copy to .env.test and fill in your test database credentials:
#   cp .env.test.example .env.test

NODE_ENV=test

# Test Database (should be a SEPARATE database from development/production)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cacd_archive_test
DB_USER=cacd_test_user
DB_PASSWORD=your_test_password_here

# Disable features not needed during testing
EMAIL_NOTIFICATIONS_ENABLED=false
SCRAPE_ON_STARTUP=false
SKIP_STARTUP_FILESYSTEM_CHECK=true

# Auth (required — generate with: ./bin/cacd secret generate)
JWT_SECRET=test-secret-not-for-production-use-only-for-testing-1234567890
